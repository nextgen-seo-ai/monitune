<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MonitorTune.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="О программе">
    <Window.SystemBackdrop><MicaBackdrop/></Window.SystemBackdrop>

    <Grid Padding="0" RowDefinitions="Auto,*,Auto">

        <!-- Шапка -->
        <Border Grid.Row="0" Padding="24,20,24,16">
            <StackPanel Orientation="Horizontal" Spacing="14">
                <Image Width="48" Height="48"
                       Source="ms-appx:///Assets/Square150x150Logo.scale-200.png"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="MoniTune"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock x:Name="VersionText"
                               FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Прокручиваемое содержимое.
             HorizontalScrollMode/Visibility=Disabled — иначе StackPanel внутри
             получает "бесконечную" ширину и TextWrapping не срабатывает. -->
        <ScrollViewer Grid.Row="1" Padding="24,0,24,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ContentHost" Spacing="20"
                        HorizontalAlignment="Stretch"/>
        </ScrollViewer>

        <!-- Низ: кнопка -->
        <Border Grid.Row="2" Padding="24,12,24,18">
            <Button Content="Закрыть"
                    Click="CloseClick"
                    HorizontalAlignment="Right"
                    MinWidth="100"/>
        </Border>
    </Grid>
</Window>
